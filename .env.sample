# =============================================================================
# Lightning Data Pipeline — Environment Variables
# =============================================================================
# FIRST DEPLOYMENT:
#   1. Copy this file to .env:  cp .env.sample .env
#   2. Fill in the values below (especially passwords)
#   3. Run: docker compose up -d
#
# The containers will automatically:
#   - Create the MariaDB database and user (from MARIADB_* variables)
#   - Wait for MariaDB to be ready
#   - Create the 'events' table and indexes
#   - Start the REST API
#
# If anything is misconfigured, the container logs will tell you exactly
# what's wrong and how to fix it:
#   docker compose logs db-init
#   docker compose logs lightning-api
# =============================================================================

# --- MariaDB Container (used by the official mariadb:11 image) ---
# Root password for the MariaDB instance (only used internally by the container)
MARIADB_ROOT_PASSWORD=changeme-root

# --- Database Connection (shared by API, Collector, and db-init) ---
# Host address of the MariaDB server (use "mariadb" when running in Docker Compose)
LIGHTNING_DB_HOST=mariadb
# MariaDB port (1-65535)
LIGHTNING_DB_PORT=3306
# Database username (auto-created by MariaDB container on first start)
LIGHTNING_DB_USER=lightning
# Database password (auto-created by MariaDB container on first start)
LIGHTNING_DB_PASSWORD=changeme
# Database name (auto-created by MariaDB container on first start)
LIGHTNING_DB_NAME=lightning_events

# --- Lightning API Service ---
# Bind address for the API server (0.0.0.0 = all interfaces inside container)
LIGHTNING_API_HOST=0.0.0.0
# Port the API listens on (1-65535)
LIGHTNING_API_PORT=8000
# Allowed CORS origins as a JSON list (use ["*"] for development)
LIGHTNING_CORS_ORIGINS=["*"]
# MariaDB connection pool size for the API
LIGHTNING_DB_POOL_SIZE=5

# --- Lightning Collector Service (runs on Raspberry Pi host, NOT in Docker) ---
# Uncomment and configure these on the Pi where the collector runs natively.
# The collector needs LIGHTNING_DB_HOST pointed at the Docker host IP.
#
# LIGHTNING_CSV_FILE_PATH=/var/lib/lightning/events.csv
# LIGHTNING_SENSOR_I2C_ADDRESS=3
# LIGHTNING_SENSOR_I2C_BUS=1
# LIGHTNING_SENSOR_IRQ_PIN=4
# LIGHTNING_BUFFER_MAX_SIZE=10000
